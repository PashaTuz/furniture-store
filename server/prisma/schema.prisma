generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ЕНУМЕРАЦІЇ ---
enum Role {
  USER
  ADMIN
}

// --- КОРИСТУВАЧІ ---
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Хеш пароля
  name      String?
  role      Role     @default(USER)
  refreshToken String?
  orders    Order[]  // Зв'язок: один користувач -> багато замовлень
  createdAt DateTime @default(now())
}

// --- ТОВАРИ ---
model Product {
  id          String         @id @default(cuid())
  name        String
  description String?
  category    String
  
  colors      ProductColor[]
  sizes       ProductSize[]
  orderItems  OrderItem[]

  createdAt   DateTime       @default(now())
}

// --- ВАРІАЦІЇ КОЛЬОРІВ ---
model ProductColor {
  id        String  @id @default(cuid())
  name      String
  imageUrl  String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// --- ВАРІАЦІЇ РОЗМІРІВ ---
model ProductSize {
  id        String  @id @default(cuid())
  name      String
  price     Float
  comment   String?
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// --- ЗАМОВЛЕННЯ ---
model Order {
  id        Int         @id @default(autoincrement())
  userId    String      // Змінено з Int на String, щоб відповідати User.id (cuid)
  user      User        @relation(fields: [userId], references: [id])
  items     OrderItem[]
  total     Float
  status    String      @default("PENDING")
  createdAt DateTime    @default(now())
}

// --- ТОВАРИ У ЗАМОВЛЕННІ ---
model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  
  productId String
  product   Product @relation(fields: [productId], references: [id])
  
  quantity  Int
  price     Float
}