{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "./",
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    /* Ми прибрали moduleResolution, щоб дозволити TS обрати найкращий варіант автоматично */
    /* Або використай "node", але без додаткових прапорців ігнорування, якщо вони видають помилку */
    "moduleResolution": "node"
  },
  "include": [
    "src/**/*",
    "prisma/seed.ts",
    "prisma/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}